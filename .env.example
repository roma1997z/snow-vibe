SNOW_VIBE_TELEGRAM_BOT_TOKEN=replace-me
SNOW_VIBE_ADMIN_USERNAME=admin
SNOW_VIBE_ADMIN_PASSWORD=replace-me
SNOW_VIBE_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
